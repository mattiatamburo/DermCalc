<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DermCalc" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Disabilita animazioni tra activity -->
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>

        <!-- Font simile a Comic Sans -->
        <item name="android:fontFamily">sans-serif-casual</item>
        <item name="fontFamily">sans-serif-casual</item>

        <!-- Material 3 Colors - Light Mode -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">#E0E0E0</item>
        <item name="colorOnSurfaceVariant">#49454F</item>
    </style>

    <style name="Theme.DermCalc" parent="Base.Theme.DermCalc" />
</resources>