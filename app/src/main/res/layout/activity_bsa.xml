<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_BSA"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/desc_BSA"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bsa_Testa"
            android:textStyle="bold"
            android:textColor="#E64A19"/>

        <EditText
            android:id="@+id/editBsaTesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_BSA"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bsa_ArtiSup"
            android:textStyle="bold"
            android:textColor="#E64A19"/>

        <EditText
            android:id="@+id/editBsaArtiSup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_BSA"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bsa_Tronco"
            android:textStyle="bold"
            android:textColor="#E64A19"/>

        <EditText
            android:id="@+id/editBsaTronco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_BSA"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bsa_ArtiInf"
            android:textStyle="bold"
            android:textColor="#E64A19"/>
        <EditText
            android:id="@+id/editBsaArtiInf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_BSA"
            android:inputType="numberDecimal"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:id="@+id/layoutRisultatoBsa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#FBE9E7"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/textRisultatoBsa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#D84315"/>

            <TextView
                android:id="@+id/textSeveritaBsa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#BF360C"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <Button
                android:id="@+id/btn_Annulla"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_Annulla"
                style="?attr/materialButtonOutlinedStyle"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnCalcolaSalva"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_Calcola"
                android:textSize="16sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnModifica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_Modifica"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="#757575"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>