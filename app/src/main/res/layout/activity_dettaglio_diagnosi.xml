<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitolo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/textTitolo"
            android:textColor="?attr/colorOnSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtDettaglioTipo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:text="@string/textDettaglioTipo"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/txtDettaglioData"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtTitolo" />

        <TextView
            android:id="@+id/txtDettaglioData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/textDettaglioDataDefault"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:alpha="0.7"
            app:layout_constraintBottom_toBottomOf="@+id/txtDettaglioTipo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/txtDettaglioTipo" />

        <View
            android:id="@+id/separatore"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?attr/colorSurfaceVariant"
            app:layout_constraintTop_toBottomOf="@+id/txtDettaglioTipo" />

        <LinearLayout
            android:id="@+id/boxRisultato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="?attr/colorSurfaceVariant"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/separatore">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/textDettaglioRisultato"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDettaglioRisultato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="--"
                android:textColor="?attr/colorOnSurface"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDettaglioSeverita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/textDettaglioSeverita"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtTitoloNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/textTitoloNote"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/boxRisultato" />

        <TextView
            android:id="@+id/txtDettaglioNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:padding="16dp"
            android:text="@string/textDettaglioNote"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@+id/txtTitoloNote" />

        <Button
            android:id="@+id/btnChiudiDettaglio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="32dp"
            android:text="@string/btnChiudiDettaglio"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtDettaglioNote"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>